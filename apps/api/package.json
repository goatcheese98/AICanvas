{
	"name": "@ai-canvas/api",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"dev": "node ../../scripts/run-api-dev.mjs",
		"build": "wrangler deploy --dry-run --outdir dist",
		"deploy": "wrangler deploy",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply ai-canvas-db --local"
	},
	"dependencies": {
		"@ai-canvas/shared": "workspace:*",
		"@anthropic-ai/sdk": "^0.71.2",
		"@clerk/backend": "^1.21.0",
		"@hono/zod-validator": "^0.7.6",
		"@sentry/cloudflare": "^10.43.0",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.6.14",
		"nanoid": "^5.1.6",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260313.1",
		"drizzle-kit": "^0.30.1",
		"vitest": "^2.1.8",
		"wrangler": "^4.73.0"
	}
}
