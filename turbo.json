{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": [".env", ".env.local"],
	"globalEnv": [
		"VITE_PORT",
		"VITE_API_PROXY_TARGET",
		"VITE_API_BASE_URL",
		"VITE_CLERK_PUBLISHABLE_KEY",
		"VITE_PARTYKIT_HOST",
		"API_PORT"
	],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".output/**"]
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"lint": {},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		}
	}
}
