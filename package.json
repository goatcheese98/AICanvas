{
	"name": "ai-canvas",
	"private": true,
	"workspaces": ["apps/*", "packages/*", "workers/*"],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"worktree:new": "node scripts/create-worktree.mjs",
		"smoke:deploy": "bun scripts/deploy-smoke-check.mjs",
		"test": "turbo test",
		"typecheck": "turbo typecheck",
		"db:generate": "turbo db:generate --filter=@ai-canvas/api",
		"db:migrate": "turbo db:migrate --filter=@ai-canvas/api"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"turbo": "^2.8.17",
		"typescript": "^5.9.3"
	},
	"packageManager": "bun@1.3.9",
	"engines": {
		"node": ">=20"
	}
}
